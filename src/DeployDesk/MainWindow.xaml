<Window x:Class="DeployDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="DeployDesk" Height="900" Width="1380" MinHeight="720" MinWidth="1080"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource TextBrush}"
        AllowDrop="True" UseLayoutRounding="True" SnapsToDevicePixels="True" Opacity="0"
        Loaded="Window_Loaded" StateChanged="Window_StateChanged"
        Drop="Window_Drop" DragOver="Window_DragOver" PreviewKeyDown="Window_PreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="7" GlassFrameThickness="0"
                            CornerRadius="10" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="StatCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="16,14" />
        </Style>

        <Style x:Key="Eyebrow" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TertiaryBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ProjectListItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="SelectionBar" Width="2" HorizontalAlignment="Left" Margin="0,9"
                                    CornerRadius="1" Background="{StaticResource AccentBrush}" Opacity="0" />
                            <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,10">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1B1D1E" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#202223" />
                                <Setter TargetName="SelectionBar" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,3" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="CompactBorder" Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,6">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CompactBorder" Property="Background" Value="#1E2021" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource FieldBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="ComboRoot" SnapsToDevicePixels="True">
                            <ToggleButton x:Name="DropDownToggle" Focusable="False" ClickMode="Press"
                                          Foreground="{TemplateBinding Foreground}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="FieldBorder" Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="7">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="32" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Margin="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center" HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  IsHitTestVisible="False" />
                                                <Border Grid.Column="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                                                    <Path x:Name="Arrow" Data="M 0 0 L 4 4 L 8 0" Stroke="{StaticResource MutedBrush}"
                                                          StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="FieldBorder" Property="Background" Value="#1A1C1D" />
                                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource MutedBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Margin="0,4,0,0" MinWidth="{Binding ActualWidth, ElementName=ComboRoot}"
                                        MaxHeight="260" Background="#181A1B" BorderBrush="{StaticResource BorderStrongBrush}"
                                        BorderThickness="1" CornerRadius="7" Padding="4">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                                  CanContentScroll="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboRoot" Property="Opacity" Value="0.72" />
                                <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#252829" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="RunningStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="DeployGlow" Storyboard.TargetProperty="Opacity"
                             From="0.08" To="0.28" Duration="0:0:0.85" AutoReverse="True" />
            <DoubleAnimation Storyboard.TargetName="ActivityPulse" Storyboard.TargetProperty="Opacity"
                             From="0.35" To="1" Duration="0:0:0.72" AutoReverse="True" />
            <DoubleAnimation Storyboard.TargetName="ProgressTranslate" Storyboard.TargetProperty="X"
                             From="-190" To="1000" Duration="0:0:1.65" />
        </Storyboard>
    </Window.Resources>

    <Border x:Name="WindowFrame" Background="{StaticResource BackgroundBrush}" BorderBrush="#303235" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Eigene, ruhige Titelleiste -->
            <Grid Grid.Row="0" Background="#0E0F10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Width="24" Height="24" CornerRadius="6" ClipToBounds="True" Background="#17211B">
                        <Image Source="Assets/DeployDesk.ico" Stretch="UniformToFill" />
                    </Border>
                    <TextBlock Text="DeployDesk" FontSize="13" FontWeight="SemiBold" Margin="9,0,0,0" VerticalAlignment="Center" />
                    <Border Background="#191B1C" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="5" Padding="6,2" Margin="9,0,0,0">
                        <TextBlock Text="{Binding ApplicationVersion}" FontSize="9" Foreground="{StaticResource TertiaryBrush}" />
                    </Border>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Texts[WindowSubtitle]}" Foreground="{StaticResource TertiaryBrush}"
                           FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,6,0">
                    <Button Style="{StaticResource TitleButton}" Click="Settings_Click" ToolTip="{Binding Texts[SettingsShortcut]}">
                        <TextBlock Text="⚙" FontSize="14" />
                    </Button>
                    <Button Style="{StaticResource TitleButton}" Click="Minimize_Click" ToolTip="{Binding Texts[Minimize]}">
                        <TextBlock Text="—" FontSize="13" />
                    </Button>
                    <Button Style="{StaticResource TitleButton}" Click="Maximize_Click" ToolTip="{Binding Texts[Maximize]}">
                        <TextBlock x:Name="MaximizeGlyph" Text="□" FontSize="15" />
                    </Button>
                    <Button Style="{StaticResource TitleButton}" Click="Close_Click" ToolTip="{Binding Texts[Close]}">
                        <TextBlock Text="×" FontSize="18" />
                    </Button>
                </StackPanel>
                <Border VerticalAlignment="Bottom" Height="1" Background="#202224" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="272" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Projekt-Navigation -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="#242628" BorderThickness="0,0,1,0">
                    <Grid Margin="14,16,14,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Margin="6,0,6,13">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Texts[Projects]}" Style="{StaticResource Eyebrow}" />
                                <TextBlock Text="{Binding Texts[DeploymentTargets]}" FontSize="17" FontWeight="SemiBold" Margin="0,5,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="#1A1C1D" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="9" MinWidth="30" Height="30" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Projects.Count}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="11" Foreground="{StaticResource MutedBrush}" />
                            </Border>
                        </Grid>

                        <Button Grid.Row="1" Style="{StaticResource AccentButton}" Click="Import_Click" Margin="0,0,0,13" Padding="13,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="＋" Foreground="{StaticResource PrimaryTextBrush}" FontSize="15" Margin="0,-1,7,0" />
                                <TextBlock Text="{Binding Texts[AddProject]}" Foreground="{StaticResource PrimaryTextBrush}" />
                            </StackPanel>
                        </Button>

                        <ListBox Grid.Row="2" ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}"
                                 ItemContainerStyle="{StaticResource ProjectListItem}" Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}" VerticalAlignment="Top" Margin="1,6,10,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TertiaryBrush}" FontSize="10.5"
                                                       Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="›" Foreground="{StaticResource TertiaryBrush}" FontSize="17"
                                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="3">
                            <Border Background="#151617" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="9" Padding="11,10" Margin="0,10,0,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Texts[DropZone]}" Style="{StaticResource Eyebrow}" />
                                    <TextBlock Text="{Binding Texts[DropHint]}" Foreground="{StaticResource MutedBrush}"
                                               FontSize="11" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Button Style="{StaticResource GhostButton}" Click="RemoveProject_Click" IsEnabled="{Binding HasProject}" Padding="10,7">
                                <TextBlock Text="{Binding Texts[RemoveProject]}" Foreground="{StaticResource TertiaryBrush}" FontSize="11" />
                            </Button>
                            <Border Background="{StaticResource BorderBrush}" Height="1" Margin="4,8,4,10" />
                            <Button Style="{StaticResource FlatButton}" Click="Settings_Click" Padding="12,9"
                                    HorizontalContentAlignment="Stretch"
                                    ToolTip="{Binding Texts[SettingsShortcut]}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Texts[Settings]}" Margin="9,0,0,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="Ctrl+," Foreground="{StaticResource TertiaryBrush}"
                                               FontSize="10" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Arbeitsbereich -->
                <Grid x:Name="ContentHost" Grid.Column="1" Margin="24,20,24,24" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="ContentTranslate" />
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Projektkopf -->
                    <Grid Grid.Row="0" Margin="2,0,2,17">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Texts[Workspace]}" Style="{StaticResource Eyebrow}" VerticalAlignment="Center" />
                                <TextBlock Text="/" Foreground="{StaticResource TertiaryBrush}" Margin="8,0" />
                                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="5" Padding="7,2">
                                    <TextBlock Text="{Binding ServerEnvironment}" Foreground="{StaticResource AccentBrush}" FontSize="9" FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Text="{Binding ServerSummary}" Foreground="{StaticResource TertiaryBrush}" FontSize="10"
                                           Margin="9,0,0,0" VerticalAlignment="Center" MaxWidth="420" TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding ServerSummary}" />
                            </StackPanel>
                            <TextBlock Text="{Binding ProjectName}" FontSize="28" FontWeight="SemiBold" Margin="0,7,0,0" />
                            <TextBlock Text="{Binding ProjectDescription}" Foreground="{StaticResource MutedBrush}" FontSize="12"
                                       Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Style="{StaticResource GhostButton}" Click="OpenWebsite_Click" IsEnabled="{Binding CanOpenWebsite}" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Texts[Website]}" />
                                    <TextBlock Text="↗" Foreground="{StaticResource MutedBrush}" Margin="7,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Click="OpenRepository_Click" IsEnabled="{Binding HasProject}" Margin="0,0,4,0">
                                <TextBlock Text="{Binding Texts[Repository]}" />
                            </Button>
                            <Button Style="{StaticResource FlatButton}" Click="Refresh_Click" IsEnabled="{Binding CanRefresh}" Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↻" Foreground="{StaticResource MutedBrush}" FontSize="15" Margin="0,-1,6,0" />
                                    <TextBlock Text="{Binding Texts[Sync]}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Kompakte Statusübersicht -->
                    <Grid Grid.Row="1" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource StatCard}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Texts[Branch]}" Style="{StaticResource Eyebrow}" />
                                    <TextBlock Text="{Binding Branch}" FontSize="15" FontWeight="SemiBold" Margin="0,5,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="⌘" Foreground="{StaticResource TertiaryBrush}" FontSize="15" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource StatCard}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Texts[Worktree]}" Style="{StaticResource Eyebrow}" />
                                    <TextBlock Text="{Binding DirtySummary}" FontSize="15" FontWeight="SemiBold" Margin="0,5,0,0" />
                                </StackPanel>
                                <Ellipse Grid.Column="1" Width="7" Height="7" Fill="{StaticResource WarningBrush}" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="4" Style="{StaticResource StatCard}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Texts[Pending]}" Style="{StaticResource Eyebrow}" />
                                    <TextBlock Text="{Binding UndeployedSummary}" FontSize="15" FontWeight="SemiBold" Margin="0,5,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="↑" Foreground="{StaticResource AccentBrush}" FontSize="16" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="6" Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="{Binding Texts[LastDeploy]}" Style="{StaticResource Eyebrow}" />
                                <TextBlock Text="{Binding LastDeploySummary}" FontSize="15" FontWeight="SemiBold" Margin="0,5,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Primärer Deployment-Bereich -->
                    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="20" Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="3" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="30" Height="30" CornerRadius="8" Background="#202422" BorderBrush="#304338" BorderThickness="1">
                                        <TextBlock Text="↑" Foreground="{StaticResource AccentBrush}" FontSize="16" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0" />
                                    </Border>
                                    <StackPanel Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Texts[Deployment]}" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="{Binding Texts[DeploymentSubtitle]}" Foreground="{StaticResource TertiaryBrush}" FontSize="10.5" Margin="0,2,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#151817" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="12" Padding="10,5" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="ActivityPulse" Width="6" Height="6" Fill="{StaticResource AccentBrush}" Margin="0,0,7,0" />
                                        <TextBlock Text="{Binding DeployStatus}" Foreground="{Binding StatusBrush}" FontSize="10.5" MaxWidth="300" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,17,0,17">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="250" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Texts[CommitMessage]}" Style="{StaticResource Eyebrow}" />
                                    <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}" Margin="0,7,0,10"
                                             ToolTip="{Binding Texts[CommitMessageHint]}" />
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox Content="{Binding Texts[AutoCommit]}" IsChecked="{Binding AutoCommit}" Margin="0,0,18,0" />
                                        <ItemsControl ItemsSource="{Binding Options}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected}" ToolTip="{Binding Description}" Margin="0,0,18,0">
                                                        <TextBlock Text="{Binding Label}" />
                                                    </CheckBox>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>

                                <Grid Grid.Column="2">
                                    <Border x:Name="DeployGlow" Background="{StaticResource AccentBrush}" CornerRadius="12" Margin="-4" Opacity="0" />
                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <Button Style="{StaticResource AccentButton}" Click="Deploy_Click" IsEnabled="{Binding CanDeploy}" Padding="18,15">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="↑" Foreground="{StaticResource PrimaryTextBrush}" FontSize="18" FontWeight="Bold" Margin="0,-2,8,0" />
                                                    <TextBlock Text="{Binding DeployActionLabel}" Foreground="{StaticResource PrimaryTextBrush}"
                                                               FontWeight="SemiBold" FontSize="13" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding DeployActionHint}" Foreground="#666865" FontSize="9.5"
                                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="1" Style="{StaticResource GhostButton}" Click="Cancel_Click" IsEnabled="{Binding CanCancel}"
                                                Visibility="{Binding ProgressVisibility}" Margin="0,5,0,0" Padding="8,5">
                                            <TextBlock Text="{Binding Texts[CancelDeployment]}" Foreground="{StaticResource DangerBrush}" FontSize="10.5" />
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Grid>

                            <Border Grid.Row="2" Background="#222526" CornerRadius="2" ClipToBounds="True"
                                    Visibility="{Binding ProgressVisibility}">
                                <Border x:Name="ProgressSegment" Width="190" HorizontalAlignment="Left" CornerRadius="2" Background="{StaticResource AccentBrush}">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="ProgressTranslate" X="-190" />
                                    </Border.RenderTransform>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Repository und Live-Aktivität -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.82*" MinWidth="310" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="1.35*" MinWidth="430" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="1" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Margin="17,15,17,10">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                    <Grid>
                                        <TextBlock Text="{Binding Texts[LocalChanges]}" Style="{StaticResource SectionTitle}" />
                                        <Border HorizontalAlignment="Right" Background="#20201B" CornerRadius="8" Padding="7,3">
                                            <TextBlock Text="{Binding Changes.Count}" Foreground="{StaticResource WarningBrush}" FontSize="10" />
                                        </Border>
                                    </Grid>
                                    <ListBox Grid.Row="1" ItemsSource="{Binding Changes}" ItemContainerStyle="{StaticResource CompactListItem}"
                                             Background="Transparent" BorderThickness="0" Foreground="{StaticResource WarningBrush}"
                                             FontFamily="Cascadia Mono, Consolas" FontSize="10.5" Margin="-8,8,-8,0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                                </Grid>

                                <Border Grid.Row="1" Background="{StaticResource BorderBrush}" />

                                <Grid Grid.Row="2" Margin="17,13,17,10">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                    <TextBlock Text="{Binding Texts[RecentCommits]}" Style="{StaticResource SectionTitle}" />
                                    <ListBox Grid.Row="1" ItemsSource="{Binding Commits}" ItemContainerStyle="{StaticResource CompactListItem}"
                                             Background="Transparent" BorderThickness="0" FontFamily="Cascadia Mono, Consolas"
                                             FontSize="10.5" Margin="-8,7,-8,0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ToolTip="{Binding RelativeTime}">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Hash}" Foreground="{StaticResource IndigoBrush}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Subject}" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="1" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Margin="17,14">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Texts[DeploymentActivity]}" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="{Binding Texts[RunnerLiveOutput]}" Foreground="{StaticResource TertiaryBrush}" FontSize="10.5" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Style="{StaticResource GhostButton}" Click="CopyLog_Click" Padding="10,6">
                                        <StackPanel Orientation="Horizontal">
                                            <Grid Width="12" Height="12" Margin="0,0,7,0" VerticalAlignment="Center">
                                                <Border Width="8" Height="8" BorderBrush="{StaticResource TertiaryBrush}" BorderThickness="1"
                                                        CornerRadius="1" HorizontalAlignment="Right" VerticalAlignment="Top" />
                                                <Border Width="8" Height="8" BorderBrush="{StaticResource TertiaryBrush}" BorderThickness="1"
                                                        CornerRadius="1" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="{StaticResource PanelBrush}" />
                                            </Grid>
                                            <TextBlock Text="{Binding Texts[CopyLog]}" FontSize="10.5" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <Border Grid.Row="1" Background="{StaticResource BorderBrush}" />
                                <TextBox x:Name="LogBox" Grid.Row="2" Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True"
                                         TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Cascadia Mono, Consolas" FontSize="10.5" Padding="15,12" BorderThickness="0"
                                         Background="#111213" Foreground="#C9CBCC" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Grid Grid.RowSpan="2" Panel.ZIndex="50" Visibility="{Binding SettingsVisibility}">
                <Button Style="{StaticResource GhostButton}" Background="#B0000000" BorderThickness="0"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="CloseSettings_Click" />

                <Border Width="430" HorizontalAlignment="Right" Background="{StaticResource SidebarBrush}"
                        BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1,0,0,0"
                        Padding="24,22" Effect="{x:Null}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Texts[SettingsTitle]}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Texts[SettingsSubtitle]}" Foreground="{StaticResource MutedBrush}"
                                           FontSize="11.5" Margin="0,5,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource TitleButton}" Click="CloseSettings_Click"
                                    ToolTip="{Binding Texts[Close]}">
                                <TextBlock Text="×" FontSize="18" />
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <Border Style="{StaticResource SettingsCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="140" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,14,0">
                                            <TextBlock Text="{Binding Texts[Language]}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Texts[LanguageDescription]}" Foreground="{StaticResource TertiaryBrush}"
                                                       FontSize="10.5" TextWrapping="Wrap" Margin="0,4,0,0" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1" SelectedValue="{Binding LanguageCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Tag" VerticalAlignment="Center">
                                            <ComboBoxItem Tag="en" Content="English" />
                                            <ComboBoxItem Tag="de" Content="Deutsch" />
                                        </ComboBox>
                                    </Grid>
                                </Border>

                                <TextBlock Text="{Binding Texts[RefreshSection]}" Style="{StaticResource Eyebrow}" Margin="3,6,0,8" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <StackPanel>
                                        <CheckBox Content="{Binding Texts[AutoRefresh]}" IsChecked="{Binding AutoRefreshEnabled, Mode=TwoWay}" />
                                        <TextBlock Text="{Binding Texts[AutoRefreshDescription]}" Foreground="{StaticResource TertiaryBrush}"
                                                   FontSize="10.5" TextWrapping="Wrap" Margin="25,5,0,15" />
                                        <Grid IsEnabled="{Binding AutoRefreshEnabled}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Texts[RefreshInterval]}" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1" ItemsSource="{Binding RefreshIntervalOptions}"
                                                      SelectedValue="{Binding AutoRefreshIntervalSeconds, Mode=TwoWay}"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding Texts[Seconds]}" Foreground="{StaticResource MutedBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding Texts[SafetySection]}" Style="{StaticResource Eyebrow}" Margin="3,6,0,8" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <StackPanel>
                                        <CheckBox Content="{Binding Texts[ConfirmDeploy]}" IsChecked="{Binding ConfirmBeforeDeploy, Mode=TwoWay}" />
                                        <TextBlock Text="{Binding Texts[ConfirmDeployDescription]}" Foreground="{StaticResource TertiaryBrush}"
                                                   FontSize="10.5" TextWrapping="Wrap" Margin="25,5,0,16" />
                                        <CheckBox Content="{Binding Texts[ClearLog]}" IsChecked="{Binding ClearLogBeforeDeploy, Mode=TwoWay}" />
                                        <TextBlock Text="{Binding Texts[ClearLogDescription]}" Foreground="{StaticResource TertiaryBrush}"
                                                   FontSize="10.5" TextWrapping="Wrap" Margin="25,5,0,0" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding Texts[LogSection]}" Style="{StaticResource Eyebrow}" Margin="3,6,0,8" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <StackPanel>
                                        <CheckBox Content="{Binding Texts[AutoScrollLog]}" IsChecked="{Binding AutoScrollLog, Mode=TwoWay}" />
                                        <TextBlock Text="{Binding Texts[AutoScrollLogDescription]}" Foreground="{StaticResource TertiaryBrush}"
                                                   FontSize="10.5" TextWrapping="Wrap" Margin="25,5,0,0" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding Texts[AboutSection]}" Style="{StaticResource Eyebrow}" Margin="3,6,0,8" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Texts[ApplicationVersion]}" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{Binding ApplicationVersion}"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2" Background="#151817" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="11,9" Margin="0,14,0,0">
                            <TextBlock Text="{Binding Texts[SettingsSaved]}" Foreground="{StaticResource TertiaryBrush}"
                                       FontSize="10.5" HorizontalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
