<Window x:Class="DeployDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DeployDesk" Height="860" Width="1280" MinHeight="700" MinWidth="1020"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}" AllowDrop="True"
        Drop="Window_Drop" DragOver="Window_DragOver">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="9" Padding="12,10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#253347" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#131722" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="4,5,4,18">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource AccentBrush}">
                            <TextBlock Text="↑" Foreground="#07150D" FontSize="25" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-3,0,0" />
                        </Border>
                        <TextBlock Text="DeployDesk" FontSize="20" FontWeight="Bold" Margin="10,4,0,0" />
                    </StackPanel>
                    <TextBlock Text="Leichtes Deployment für deine Repos" Foreground="{StaticResource MutedBrush}"
                               FontSize="11" Margin="0,9,0,0" />
                </StackPanel>

                <Button Grid.Row="1" Style="{StaticResource AccentButton}" Click="Import_Click" Margin="0,0,0,14">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="＋" Foreground="#07150D" FontWeight="Bold" Margin="0,0,7,0" />
                        <TextBlock Text="Projekt hinzufügen" Foreground="#07150D" FontWeight="Bold" />
                    </StackPanel>
                </Button>

                <ListBox Grid.Row="2" ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}"
                         Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Status}" Foreground="{StaticResource MutedBrush}" FontSize="11"
                                           Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="Du kannst eine .deploylink-Datei auch hierher ziehen."
                               Foreground="{StaticResource MutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="4,8" />
                    <Button Style="{StaticResource FlatButton}" Click="RemoveProject_Click" IsEnabled="{Binding HasProject}">
                        <TextBlock Text="Projekt entfernen" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="24,20,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding ProjectName}" FontSize="25" FontWeight="Bold" />
                    <TextBlock Text="{Binding ProjectDescription}" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource FlatButton}" Click="OpenWebsite_Click" IsEnabled="{Binding CanOpenWebsite}" Margin="0,0,8,0">
                        <TextBlock Text="Website öffnen" />
                    </Button>
                    <Button Style="{StaticResource FlatButton}" Click="OpenRepository_Click" IsEnabled="{Binding HasProject}" Margin="0,0,8,0">
                        <TextBlock Text="Repo öffnen" />
                    </Button>
                    <Button Style="{StaticResource FlatButton}" Click="Refresh_Click" IsEnabled="{Binding CanRefresh}">
                        <TextBlock Text="Aktualisieren" />
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,18,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="BRANCH" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Bold" />
                        <TextBlock Text="{Binding Branch}" FontSize="16" FontWeight="SemiBold" Margin="0,5,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="ARBEITSVERZEICHNIS" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Bold" />
                        <TextBlock Text="{Binding DirtySummary}" FontSize="16" FontWeight="SemiBold" Margin="0,5,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="DEPLOY-STATUS" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Bold" />
                        <TextBlock Text="{Binding UndeployedSummary}" FontSize="16" FontWeight="SemiBold" Margin="0,5,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="230" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Commit-Nachricht" FontWeight="SemiBold" />
                        <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}" Margin="0,7,0,9"
                                 ToolTip="Leer lassen, um automatisch Datum und Uhrzeit zu verwenden." />
                        <CheckBox Content="Lokale Änderungen vor dem Deploy committen" IsChecked="{Binding AutoCommit}" />
                        <ItemsControl ItemsSource="{Binding Options}" Margin="0,9,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" Margin="0,3,0,0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Label}" />
                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedBrush}" FontSize="10" />
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Button Style="{StaticResource AccentButton}" Click="Deploy_Click" IsEnabled="{Binding CanDeploy}"
                                FontSize="18" Padding="18,18" VerticalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="DEPLOY" Foreground="#07150D" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" />
                                <TextBlock Text="Sicher veröffentlichen" Foreground="#174529" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="1" Style="{StaticResource FlatButton}" Click="Cancel_Click" IsEnabled="{Binding CanCancel}" Margin="0,8,0,0">
                            <TextBlock Text="Abbrechen" Foreground="{StaticResource DangerBrush}" />
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="180" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Lokale Änderungen" FontWeight="SemiBold" Margin="0,0,0,9" />
                            <ListBox Grid.Row="1" ItemsSource="{Binding Changes}" Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource WarningBrush}" FontFamily="Cascadia Mono,Consolas" FontSize="11" />
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Letzte Commits" FontWeight="SemiBold" Margin="0,0,0,9" />
                            <ListBox Grid.Row="1" ItemsSource="{Binding Commits}" Background="Transparent" BorderThickness="0"
                                     FontFamily="Cascadia Mono,Consolas" FontSize="11">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ToolTip="{Binding RelativeTime}">
                                            <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="4" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Live-Log" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding DeployStatus}" Foreground="{Binding StatusBrush}" FontSize="11" Margin="0,3,0,7" />
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource FlatButton}" Click="CopyLog_Click" Padding="12,6">
                                <TextBlock Text="Log kopieren" FontSize="11" />
                            </Button>
                        </Grid>
                        <ProgressBar Grid.Row="1" IsIndeterminate="True" Visibility="{Binding ProgressVisibility}"
                                     Foreground="{StaticResource AccentBrush}" Background="{StaticResource FieldBrush}" />
                        <TextBox x:Name="LogBox" Grid.Row="2" Text="{Binding LogText}" IsReadOnly="True" AcceptsReturn="True"
                                 TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Cascadia Mono,Consolas" FontSize="11" Padding="11" Margin="0,8,0,0" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
