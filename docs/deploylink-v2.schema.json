{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deploydesk.local/schema/deploylink-v2.json",
  "title": "DeployDesk project link",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "project", "repository", "server", "runner"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "accentColor": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["remote", "branch"],
      "properties": {
        "remote": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$" },
        "branch": { "type": "string", "maxLength": 255, "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$" }
      }
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "user", "sshPort", "remotePath", "healthCheck"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 40 },
        "host": { "type": "string", "minLength": 1, "maxLength": 253, "pattern": "^[A-Za-z0-9._:-]+$" },
        "user": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9._-]{0,31}$" },
        "sshPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "remotePath": { "type": "string", "maxLength": 1024, "pattern": "^/[A-Za-z0-9._/-]+$" },
        "healthCheck": {
          "type": "object",
          "additionalProperties": false,
          "required": ["port", "path"],
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "path": { "type": "string", "maxLength": 2048, "pattern": "^/[A-Za-z0-9._~%/?=&-]*$" },
            "expectedStatus": { "type": "integer", "minimum": 100, "maximum": 599, "default": 200 },
            "attempts": { "type": "integer", "minimum": 1, "maximum": 120, "default": 20 },
            "intervalSeconds": { "type": "integer", "minimum": 1, "maximum": 60, "default": 2 }
          }
        }
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "file", "protocol"],
      "properties": {
        "type": { "const": "powershell" },
        "file": { "type": "string", "minLength": 1 },
        "protocol": { "const": "deploydesk-jsonl-v1" },
        "arguments": { "type": "array", "items": { "type": "string" } }
      }
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "type", "argument"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "type": { "const": "boolean" },
          "default": { "type": "boolean" },
          "argument": { "type": "string", "pattern": "^-" }
        }
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
