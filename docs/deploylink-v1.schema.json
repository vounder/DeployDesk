{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deploydesk.local/schema/deploylink-v1.json",
  "title": "DeployDesk project link",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "project", "repository", "runner"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "accentColor": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["remote", "branch"],
      "properties": {
        "remote": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 }
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "file", "protocol"],
      "properties": {
        "type": { "const": "powershell" },
        "file": { "type": "string", "minLength": 1 },
        "protocol": { "const": "deploydesk-jsonl-v1" },
        "arguments": { "type": "array", "items": { "type": "string" } }
      }
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "type", "argument"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "type": { "const": "boolean" },
          "default": { "type": "boolean" },
          "argument": { "type": "string", "pattern": "^-" }
        }
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
